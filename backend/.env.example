# ─────────────────────────────────────────────────────────────
# BRIC Dashboard — Contoh file environment variable (backend)
# ─────────────────────────────────────────────────────────────
# SEMUA NILAI DI BAWAH INI HANYA CONTOH/PALSU (dummy).
# Jangan pernah mengisi file INI dengan nilai asli, dan jangan
# pernah commit file ".env" (tanpa ".example") ke Git.
#
# Cara pakai:
#   1. Copy file ini jadi ".env" (di folder yang sama, backend/.env)
#   2. Isi ".env" dengan nilai ASLI dari catatan credential terpisah
#   3. File ".env" TIDAK akan ikut ke Git (sudah diatur di .gitignore)
# ─────────────────────────────────────────────────────────────

# Port tempat backend Express berjalan (jangan diubah kecuali tahu dampaknya)
PORT=3001

# Koneksi ke database PostgreSQL. Format umum:
# postgresql://USER:PASSWORD@HOST:PORT/NAMA_DATABASE
DATABASE_URL=postgresql://dummy_user:dummy_password@localhost:5432/dummy_db

# Kunci rahasia untuk menandatangani token login (JWT).
# WAJIB diisi nilai asli & unik di production — jangan pernah dummy di server sungguhan.
JWT_SECRET=ganti-dengan-kunci-rahasia-yang-panjang-dan-acak

# Password akun default yang dibuat otomatis saat backend pertama kali jalan
# dan tabel users masih kosong.
ADMIN_PASSWORD=ganti-dengan-password-admin-yang-kuat
VIEWER_PASSWORD=ganti-dengan-password-viewer-yang-kuat

# Alamat Web App Google Apps Script (kalau backend perlu memanggilnya balik)
APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Token rahasia yang dipakai Google Apps Script untuk mengirim data sync
# ke HAMPIR SEMUA endpoint /sync (segmen, speedcash, ekspedisi, fastpay,
# farming, pa-produk, pa-arpu, asdp, pa-asdp, pa-lpd, lpd, bumdes, hunter,
# instaqris-trx, qris-ctrl/*, data-raw/*). Nilai contoh di bawah ini PALSU.
APPS_SCRIPT_TOKEN=dummy-apps-script-token-jangan-dipakai

# Token khusus untuk sync MGM PA — sengaja dibuat BEDA dari token di atas.
MGM_PA_SYNC_TOKEN=dummy-mgm-pa-token-jangan-dipakai

# Token khusus untuk sync Quick Win Q3 IQWM (Winme & InstaQRIS) — sengaja
# dibuat BEDA dari token di atas. TIDAK ADA fallback hardcoded di kode;
# kalau variabel ini belum diisi di server, endpoint sync-nya akan menolak
# semua request (401) sampai diisi.
QUICK_WIN_Q3_SYNC_TOKEN=dummy-quick-win-q3-token-jangan-dipakai

# Domain yang diizinkan mengakses API ini (CORS). Kosongkan/isi "*" untuk
# development, isi domain resmi (misal https://bmsretail.my.id) di production.
ALLOWED_ORIGIN=*

# API Key untuk fitur AI Chat (Google Gemini). Kosongkan kalau fitur AI
# tidak dipakai di environment ini.
GEMINI_API_KEY=dummy-gemini-api-key
